# Git Cheat Sheet for RStudio

git pull
git status
git add .
git commit -m "ok"
git push

git rm -r --cached .Rproj.user
git rm --cached .RData .RDataTmp .RDataTmp1 .Rhistory
git add .gitignore
git commit -m "Clean repo and ignore RStudio temporary files"

unlink(c(".Rproj.user", ".RData", ".RDataTmp", ".RDataTmp1", ".Rhistory"),
       recursive = TRUE, force = TRUE)
