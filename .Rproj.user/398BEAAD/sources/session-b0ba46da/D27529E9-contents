# renv_maintenance.R
# RStudio helper for routine renv maintenance
#
# Place this file in the root of your R project, then run in RStudio:
#   source("renv_maintenance.R")
#
# Examples:
#   renv_maintenance("status")
#   renv_maintenance("snapshot")
#   renv_maintenance("restore")
#   renv_maintenance("clean")
#   renv_maintenance("repair")
#   renv_maintenance("update", packages = c("dplyr", "ggplot2"))
#   renv_maintenance("diagnostics")
#
# Optional command-line use:
#   Rscript renv_maintenance.R status
#   Rscript renv_maintenance.R update dplyr ggplot2

ensure_renv <- function() {
  if (!requireNamespace("renv", quietly = TRUE)) {
    install.packages("renv", repos = "https://cloud.r-project.org")
  }
  invisible(TRUE)
}

project_root_check <- function() {
  has_lockfile <- file.exists("renv.lock")
  has_rproj <- length(list.files(pattern = "[.]Rproj$")) > 0
  
  if (!has_lockfile && !has_rproj) {
    warning(
      "This does not look like a project root. Run this script from the root of your RStudio project.",
      call. = FALSE
    )
  }
  invisible(TRUE)
}

print_header <- function(action) {
  cat("\n", paste(rep("=", 70), collapse = ""), "\n", sep = "")
  cat("renv maintenance action:", action, "\n")
  cat(paste(rep("=", 70), collapse = ""), "\n\n", sep = "")
}

renv_maintenance <- function(
    action = c(
      "status", "snapshot", "restore", "clean", "hydrate",
      "repair", "update", "diagnostics", "dependencies", "init"
    ),
    packages = NULL,
    prompt = interactive(),
    snapshot_type = "implicit",
    clean_library = FALSE
) {
  action <- match.arg(action)
  ensure_renv()
  project_root_check()
  print_header(action)
  
  switch(
    action,
    
    init = {
      if (file.exists("renv.lock")) {
        message("renv already appears to be initialized for this project.")
      } else {
        renv::init(bare = FALSE)
      }
    },
    
    status = {
      renv::status()
    },
    
    snapshot = {
      message("Creating/updating renv.lock ...")
      renv::snapshot(prompt = prompt, type = snapshot_type)
      message("Snapshot complete.")
    },
    
    restore = {
      message("Restoring project library from renv.lock ...")
      renv::restore(prompt = prompt)
      message("Restore complete.")
    },
    
    clean = {
      message("Cleaning unused packages from the project library/cache ...")
      renv::clean(prompt = prompt)
      if (isTRUE(clean_library)) {
        message("Rebuilding library links after clean ...")
        renv::restore(prompt = prompt)
      }
      message("Clean complete.")
    },
    
    hydrate = {
      message("Hydrating library from packages already available on this machine ...")
      renv::hydrate(packages = packages)
      message("Hydrate complete.")
    },
    
    repair = {
      message("Running a basic repair sequence ...")
      renv::status()
      message("\nStep 1: synchronize library with lockfile")
      renv::restore(prompt = prompt)
      message("\nStep 2: remove stale packages")
      renv::clean(prompt = prompt)
      message("\nStep 3: refresh lockfile")
      renv::snapshot(prompt = prompt, type = snapshot_type)
      message("\nRepair sequence complete.")
    },
    
    update = {
      if (is.null(packages) || length(packages) == 0) {
        stop(
          "For action = 'update', provide one or more package names, e.g. packages = c('dplyr', 'ggplot2').",
          call. = FALSE
        )
      }
      
      message("Updating packages: ", paste(packages, collapse = ", "))
      install.packages(packages, repos = "https://cloud.r-project.org")
      renv::snapshot(prompt = prompt, type = snapshot_type)
      message("Update and snapshot complete.")
    },
    
    diagnostics = {
      message("Collecting project diagnostics ...\n")
      cat("Working directory: ", normalizePath(getwd(), winslash = "/", mustWork = FALSE), "\n", sep = "")
      cat("R version: ", R.version.string, "\n\n", sep = "")
      
      cat("renv status\n")
      cat(paste(rep("-", 70), collapse = ""), "\n", sep = "")
      tryCatch(
        renv::status(),
        error = function(e) message("status() failed: ", conditionMessage(e))
      )
      
      cat("\nDependencies discovered in project\n")
      cat(paste(rep("-", 70), collapse = ""), "\n", sep = "")
      deps <- tryCatch(
        renv::dependencies(),
        error = function(e) {
          message("dependencies() failed: ", conditionMessage(e))
          NULL
        }
      )
      if (!is.null(deps)) print(deps)
      
      cat("\nSession info\n")
      cat(paste(rep("-", 70), collapse = ""), "\n", sep = "")
      print(utils::sessionInfo())
      
      invisible(deps)
    },
    
    dependencies = {
      deps <- renv::dependencies()
      print(deps)
      invisible(deps)
    }
  )
  
  invisible(TRUE)
}

# If run with Rscript, accept command-line args:
#   Rscript renv_maintenance.R status
#   Rscript renv_maintenance.R update dplyr ggplot2
if (!interactive()) {
  args <- commandArgs(trailingOnly = TRUE)
  
  if (length(args) >= 1) {
    action <- args[[1]]
    pkgs <- if (length(args) > 1) args[-1] else NULL
    
    tryCatch(
      renv_maintenance(action = action, packages = pkgs, prompt = FALSE),
      error = function(e) {
        message("Error: ", conditionMessage(e))
        quit(status = 1)
      }
    )
  }
}
